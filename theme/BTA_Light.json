{
  "name": "BTA Light",
  "dataColors": [
    "#378ADD",
    "#C0392B",
    "#B5D4F4",
    "#D3D1C7",
    "#6B7280",
    "#1F2A44"
  ],
  "background": "#EAECF0",
  "foreground": "#1F2A44",
  "tableAccent": "#378ADD",
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#C4C9D4"
              }
            },
            "radius": 8
          }
        ],
        "dropShadow": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#C4C9D4"
              }
            }
          }
        ],
        "fontFamily": [
          {
            "value": "Segoe UI"
          }
        ]
      }
    },
    "textbox": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#EAECF0"
              }
            }
          }
        ],
        "border": [
          {
            "show": false
          }
        ],
        "dropShadow": [
          {
            "show": false
          }
        ]
      }
    },
    "image": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#EAECF0"
              }
            }
          }
        ],
        "border": [
          {
            "show": false
          }
        ],
        "dropShadow": [
          {
            "show": false
          }
        ]
      }
    },
    "shape": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#EAECF0"
              }
            }
          }
        ],
        "border": [
          {
            "show": false
          }
        ],
        "dropShadow": [
          {
            "show": false
          }
        ]
      }
    }
  },
  "textClasses": {
    "callout": {
      "fontSize": 28,
      "fontFace": "Segoe UI",
      "color": "#1F2A44"
    },
    "title": {
      "fontSize": 13,
      "fontFace": "Segoe UI",
      "color": "#1F2A44"
    },
    "label": {
      "fontSize": 11,
      "fontFace": "Segoe UI",
      "color": "#6B7280"
    },
    "header": {
      "fontSize": 11,
      "fontFace": "Segoe UI",
      "color": "#6B7280"
    }
  }
}